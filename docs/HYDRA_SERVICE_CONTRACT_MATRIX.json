        },
        "security": {
          "type": "object"
        }
      },
      "compatibility_coercions": [
        "If transport missing, derive from fallback.selected_transport.",
        "If base_url missing, derive by precedence: tunnel_url -> upnp.public_base_url -> lan_base_url -> local.base_url.",
        "If tunnel.state missing, infer from running + tunnel_url + stale_tunnel_url + error."
